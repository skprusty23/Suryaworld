<?xml version="1.0" encoding="utf-8"?>
<!-- SuryaWorld App Icon — Background layer: deep indigo radial gradient -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Full background fill with radial gradient (indigo-600 → indigo-900) -->
    <path android:pathData="M0,0 h108 v108 H0 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76">
                <item android:offset="0.0" android:color="#FF5C6BC0"/>
                <item android:offset="0.6" android:color="#FF3949AB"/>
                <item android:offset="1.0" android:color="#FF1A237E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle top-left highlight -->
    <path android:pathData="M0,0 h108 v108 H0 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#22FFFFFF"/>
                <item android:offset="1.0" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
